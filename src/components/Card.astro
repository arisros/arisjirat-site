---
interface Props {
  title: string;
  description?: string;
  href: string;
  tags?: string[];
  date?: Date;
  category?: string;
  status?: string;
}

const { title, description, href, tags = [], date, category, status } = Astro.props;

const categoryColors: Record<string, string> = {
  study: 'border-l-blue-500',
  project: 'border-l-amber-500',
  research: 'border-l-purple-500',
  tool: 'border-l-orange-500',
  setup: 'border-l-cyan-500',
};

const categoryBadge: Record<string, string> = {
  study: 'text-blue-400 border-blue-500/30',
  project: 'text-amber-400 border-amber-500/30',
  research: 'text-purple-400 border-purple-500/30',
  tool: 'text-orange-400 border-orange-500/30',
  setup: 'text-cyan-400 border-cyan-500/30',
};
---

<a href={href} class:list={[
  'group block border border-slate-800 border-l-[3px] bg-[#111118] p-5 transition-all duration-200 hover:bg-[#14141c] hover:translate-x-1',
  categoryColors[category || ''] || 'border-l-slate-700',
]}>
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-[15px] font-bold text-slate-100 group-hover:text-amber-400 transition-colors line-clamp-2 leading-snug">
      {title}
    </h3>
    {category && (
      <span class:list={[
        'shrink-0 font-mono text-[10px] uppercase tracking-wider border px-2 py-0.5',
        categoryBadge[category] || 'text-slate-500 border-slate-700',
      ]}>
        {category}
      </span>
    )}
  </div>
  {description && (
    <p class="mt-2 text-sm text-slate-500 line-clamp-2 leading-relaxed">{description}</p>
  )}
  <div class="mt-3 flex flex-wrap items-center gap-2">
    {tags.slice(0, 3).map(tag => (
      <span class="font-mono text-[10px] px-2 py-0.5 bg-slate-950 border border-slate-800 text-slate-600">
        {tag}
      </span>
    ))}
    {date && (
      <time datetime={date.toISOString()} class="ml-auto font-mono text-[10px] text-slate-700 tracking-wider">
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
      </time>
    )}
  </div>
</a>
