---
interface Props {
  title: string;
  description?: string;
  href: string;
  tags?: string[];
  date?: Date;
  category?: string;
  status?: string;
}

const { title, description, href, tags = [], date, category, status } = Astro.props;

const categoryColors: Record<string, string> = {
  study: 'bg-blue-500/10 text-blue-400',
  project: 'bg-amber-500/10 text-amber-400',
  research: 'bg-purple-500/10 text-purple-400',
  tool: 'bg-orange-500/10 text-orange-400',
  setup: 'bg-cyan-500/10 text-cyan-400',
};
---

<a href={href} class="group block rounded-xl border border-slate-800 bg-slate-900/50 p-5 transition-all hover:border-amber-600/30 hover:bg-slate-900">
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-lg font-semibold text-slate-100 group-hover:text-amber-400 transition-colors line-clamp-2">
      {title}
    </h3>
    {category && (
      <span class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium ${categoryColors[category] || 'bg-slate-800 text-slate-400'}`}>
        {category}
      </span>
    )}
  </div>
  {description && (
    <p class="mt-2 text-sm text-slate-400 line-clamp-2">{description}</p>
  )}
  <div class="mt-4 flex flex-wrap items-center gap-2">
    {tags.slice(0, 4).map(tag => (
      <span class="rounded-md bg-slate-800 px-2 py-0.5 text-xs text-slate-500">
        {tag}
      </span>
    ))}
    {date && (
      <time datetime={date.toISOString()} class="ml-auto text-xs text-slate-600">
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
      </time>
    )}
  </div>
</a>
