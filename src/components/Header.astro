---
const navItems = [
  { label: 'Studies', href: '/studies' },
  { label: 'Projects', href: '/projects' },
  { label: 'Research', href: '/research' },
  { label: 'Tools', href: '/tools' },
  { label: 'Setup', href: '/setup' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-slate-800/80 bg-slate-950/90 backdrop-blur-md">
  <nav class="mx-auto flex max-w-[1100px] items-center h-12 px-4 sm:px-8 overflow-x-auto scrollbar-none">
    <a href="/" class="flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors mr-6 shrink-0">
      <img src="/favicon.ico" alt="arisjirat" class="h-6 w-6" />
      <span class="font-mono text-xs font-bold tracking-wider uppercase hidden sm:inline">arisjirat</span>
    </a>
    <ul class="flex items-center h-full">
      {navItems.map(item => (
        <li class="h-full">
          <a
            href={item.href}
            class:list={[
              'h-full inline-flex items-center px-3 sm:px-4 font-mono text-[10px] sm:text-xs uppercase tracking-[1.5px] border-l border-slate-800/60 transition-colors',
              currentPath.startsWith(item.href)
                ? 'text-amber-400'
                : 'text-slate-500 hover:text-amber-400',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
