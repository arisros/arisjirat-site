---
const navItems = [
  { label: 'Studies', href: '/studies' },
  { label: 'Projects', href: '/projects' },
  { label: 'Research', href: '/research' },
  { label: 'Tools', href: '/tools' },
  { label: 'Setup', href: '/setup' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-slate-800 bg-slate-950/80 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 sm:px-6 py-4">
    <a href="/" class="flex items-center gap-2 text-slate-100 hover:text-amber-400 transition-colors">
      <img src="/favicon.ico" alt="arisjirat" class="h-7 w-7" />
      <span class="font-semibold text-lg hidden sm:inline">arisjirat</span>
    </a>
    <ul class="flex items-center gap-1 sm:gap-2 text-sm">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[
              'px-2.5 py-1.5 rounded-md transition-colors',
              currentPath.startsWith(item.href)
                ? 'bg-amber-600/10 text-amber-400'
                : 'text-slate-400 hover:text-slate-100 hover:bg-slate-800',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
