---
import type { Lang } from '@/lib/content';
import { UI_STRINGS } from '@/lib/content';

interface Props {
  lang?: Lang;
}
const { lang = 'id' } = Astro.props;
const label = UI_STRINGS.switchTheme[lang];
---

<button
  id="theme-toggle"
  type="button"
  class="inline-flex h-7 w-7 items-center justify-center rounded-pill border border-border text-ink-muted hover:text-accent hover:border-accent/40 transition-colors"
  aria-label={label}
  title={label}
>
  <!-- Sun (visible in dark mode) -->
  <svg class="hidden dark:block h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
  <!-- Moon (visible in light mode) -->
  <svg class="block dark:hidden h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z" />
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch {}
  });
</script>
