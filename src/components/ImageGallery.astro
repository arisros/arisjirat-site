---
interface Props {
  images: { src: string; alt: string }[];
}

const { images } = Astro.props;
---

{images.length > 0 && (
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-8">
    {images.map(img => (
      <figure class="rounded-lg overflow-hidden border border-slate-800">
        <img src={img.src} alt={img.alt} class="w-full h-auto" loading="lazy" />
        {img.alt && (
          <figcaption class="px-3 py-2 text-xs text-slate-500 bg-slate-900">{img.alt}</figcaption>
        )}
      </figure>
    ))}
  </div>
)}
