---
interface Props {
  stats?: { label: string; value: string | number }[];
}
const { stats = [] } = Astro.props;
---

<section class="py-16 sm:py-24 animate-fade-up">
  <div class="max-w-3xl">
    <div class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[2px] text-amber-500 border border-amber-500/30 px-3 py-1 mb-6">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
      Software Engineer
    </div>
    <h1 class="text-[clamp(2.25rem,5vw,3.75rem)] font-extrabold text-slate-100 leading-[1.05] tracking-tight">
      Hey, I'm <span class="text-amber-400">Aris</span>
    </h1>
    <p class="mt-4 text-base sm:text-lg text-slate-500 leading-relaxed max-w-2xl">
      Building things with Go, TypeScript, IoT, and whatever gets the job done.
      I study, research, build, and share it all here.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/projects" class="inline-flex items-center gap-2 px-5 py-2.5 bg-amber-600 hover:bg-amber-500 text-white text-sm font-medium transition-all hover:translate-x-0.5">
        View Projects →
      </a>
      <a href="/studies" class="inline-flex items-center gap-2 px-5 py-2.5 border border-slate-700 hover:border-amber-600/40 text-slate-300 hover:text-amber-400 text-sm font-medium transition-all">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
        Browse Studies
      </a>
    </div>
  </div>
</section>

{stats.length > 0 && (
  <div class="grid grid-cols-2 sm:grid-cols-4 border border-slate-800 animate-fade-up-delay-1" style="background: rgba(17,17,24,1);">
    {stats.map(stat => (
      <div class="px-5 py-4 sm:px-7 sm:py-5 border-r border-b border-slate-800 last:border-r-0 hover:bg-slate-900/60 transition-colors">
        <div class="font-mono text-2xl sm:text-3xl font-bold text-amber-400">{stat.value}</div>
        <div class="font-mono text-[10px] uppercase tracking-[1.5px] text-slate-600 mt-1">{stat.label}</div>
      </div>
    ))}
  </div>
)}
