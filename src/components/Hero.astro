---
import type { Lang } from '@/lib/content';
import { DEFAULT_LANG, UI_STRINGS, langPrefix } from '@/lib/content';

interface Props {
  stats?: { label: string; value: string | number }[];
  lang?: Lang;
}
const { stats = [], lang = DEFAULT_LANG } = Astro.props;
const prefix = langPrefix(lang);

const copy = {
  badge: { id: 'Software Engineer', en: 'Software Engineer' },
  headlineBefore: { id: 'Hai, saya ', en: "Hey, I'm " },
  headlineName: 'Aris',
  headlineAfter: { id: ' ✌️', en: ' ✌️' },
  sub: {
    id: 'Membangun hal-hal dengan Go, TypeScript, IoT, dan apa pun yang menyelesaikan masalah. Saya belajar, meneliti, membuat, dan membagikan semuanya di sini 🏄🏽',
    en: "Building things with Go, TypeScript, IoT, and whatever gets the job done. I study, research, build, and share it all here 🏄🏽",
  },
};
---

<section class="relative py-16 sm:py-24 animate-fade-up overflow-hidden">
  <!-- Decorative orbital arc + satellite dot (Mastercard motif) -->
  <svg aria-hidden="true" class="pointer-events-none absolute -right-12 -top-8 sm:right-0 sm:top-0 w-[28rem] h-[28rem] opacity-30 text-accent" viewBox="0 0 400 400" fill="none" stroke="currentColor" stroke-width="1">
    <circle cx="320" cy="120" r="160" />
    <circle cx="320" cy="120" r="110" />
    <circle cx="320" cy="120" r="60" />
    <circle cx="380" cy="60" r="6" fill="currentColor" stroke="none" />
  </svg>

  <!-- Ghost watermark headline (cream-on-cream / ink-on-ink) — Mastercard editorial motif -->
  <div aria-hidden="true" class="pointer-events-none absolute -left-2 top-12 sm:top-16 text-[clamp(5rem,18vw,11rem)] font-extrabold tracking-tightish text-ink/[0.04] leading-none select-none">
    {copy.headlineName}
  </div>

  <div class="relative max-w-3xl">
    <div class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[2px] text-accent border border-accent/40 rounded-pill px-3 py-1 mb-6">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
      {copy.badge[lang]}
    </div>
    <h1 class="text-[clamp(2.25rem,5vw,3.75rem)] font-extrabold text-ink leading-[1.05] tracking-tight">
      {copy.headlineBefore[lang]}<span class="text-accent">{copy.headlineName}</span>{copy.headlineAfter[lang]}
    </h1>
    <p class="mt-4 text-base sm:text-lg text-ink-muted leading-relaxed max-w-2xl">
      {copy.sub[lang]}
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={`${prefix}/projects`} class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent hover:bg-accent-strong text-bg rounded-pill text-sm font-medium transition-all hover:translate-x-0.5 shadow-sm">
        {UI_STRINGS.viewProjects[lang]} →
      </a>
      <a href={`${prefix}/studies`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-pill border border-border hover:border-accent text-ink hover:text-accent text-sm font-medium transition-all">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
        {UI_STRINGS.browseStudies[lang]}
      </a>
    </div>
  </div>
</section>

{stats.length > 0 && (
  <div class="grid grid-cols-2 sm:grid-cols-4 border border-border bg-surface rounded-card overflow-hidden animate-fade-up-delay-1">
    {stats.map((stat, i) => (
      <div class:list={[
        'px-5 py-4 sm:px-7 sm:py-5 border-border hover:bg-surface-alt transition-colors',
        i % 2 === 0 ? 'border-r' : '',
        i < stats.length - 2 ? 'sm:border-b' : '',
        'border-b sm:border-b-0',
        i > 0 ? 'sm:border-l' : '',
      ]}>
        <div class="font-mono text-2xl sm:text-3xl font-bold text-accent">{stat.value}</div>
        <div class="font-mono text-[10px] uppercase tracking-[1.5px] text-ink-muted mt-1">{stat.label}</div>
      </div>
    ))}
  </div>
)}
