---
const socials = [
  { label: 'GitHub', href: 'https://github.com/arisros' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/arisjirat' },
];
---

<footer class="border-t border-slate-800 mt-auto">
  <div class="mx-auto max-w-[1100px] px-4 sm:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
    <p class="font-mono text-[11px] text-slate-600 tracking-wider">
      © {new Date().getFullYear()} arisjirat
    </p>
    <div class="flex items-center gap-6">
      {socials.map(s => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-[11px] text-slate-600 hover:text-amber-400 transition-colors tracking-wider uppercase"
        >
          {s.label}
        </a>
      ))}
    </div>
  </div>
</footer>
