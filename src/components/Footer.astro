---
const socials = [
  { label: 'GitHub', href: 'https://github.com/arisros', icon: 'github' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/arisjirat', icon: 'linkedin' },
];
---

<footer class="border-t border-slate-800 mt-auto">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-slate-500">
      © {new Date().getFullYear()} arisjirat
    </p>
    <div class="flex items-center gap-4">
      {socials.map(s => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 hover:text-green-400 transition-colors text-sm"
        >
          {s.label}
        </a>
      ))}
    </div>
  </div>
</footer>
