---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
---

<BaseLayout title="404 — Not Found">
  <Header />
  <main class="flex-1 flex items-center justify-center px-4">
    <div class="text-center py-20 animate-fade-up">
      <p class="font-mono text-8xl sm:text-[10rem] font-bold text-amber-500/10 leading-none">404</p>
      <h1 class="mt-4 text-xl font-bold text-slate-100">Page not found</h1>
      <p class="mt-2 text-sm text-slate-500">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="mt-8 inline-flex items-center gap-2 px-5 py-2.5 bg-amber-600 hover:bg-amber-500 text-white text-sm font-medium transition-all hover:translate-x-0.5">
        ← Back to Home
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
