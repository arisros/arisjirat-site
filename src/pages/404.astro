---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
---

<BaseLayout title="404 — Not Found">
  <Header />
  <main class="flex-1 flex items-center justify-center px-4">
    <div class="text-center py-20">
      <p class="text-7xl sm:text-9xl font-bold text-green-500/20">404</p>
      <h1 class="mt-4 text-2xl font-semibold text-slate-100">Page not found</h1>
      <p class="mt-2 text-slate-400">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="mt-8 inline-flex items-center gap-2 px-4 py-2 bg-green-600 hover:bg-green-500 text-white rounded-lg text-sm font-medium transition-colors">
        ← Back to Home
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
