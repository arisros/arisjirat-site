---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const featured = allPosts.filter(p => p.data.featured);
const recentPosts = allPosts
  .filter(p => p.data.date)
  .sort((a, b) => (b.data.date!.getTime() - a.data.date!.getTime()))
  .slice(0, 6);

function categoryPath(category: string) {
  if (category === 'study') return 'studies';
  if (category === 'project') return 'projects';
  if (category === 'tool') return 'tools';
  return category;
}

const sections = [
  { label: 'Studies', href: '/studies', description: 'Academic coursework and learning notes', count: allPosts.filter(p => p.data.category === 'study').length },
  { label: 'Projects', href: '/projects', description: 'Software, hardware, and everything in between', count: allPosts.filter(p => p.data.category === 'project').length },
  { label: 'Research', href: '/research', description: 'Deep dives and academic research', count: allPosts.filter(p => p.data.category === 'research').length },
  { label: 'Tools', href: '/tools', description: 'Hardware, IoT, and dev tools', count: allPosts.filter(p => p.data.category === 'tool').length },
  { label: 'Setup', href: '/setup', description: 'Workspace and infrastructure', count: allPosts.filter(p => p.data.category === 'setup').length },
];
---

<BaseLayout title="Home" description="Aris Kurniawan — Software Engineer. Studies, projects, research, tools, and setup.">
  <Header />
  <main class="flex-1 w-full max-w-5xl mx-auto px-4 sm:px-6">
    <Hero />

    <!-- Sections Overview -->
    <section class="py-12 border-t border-slate-800">
      <h2 class="text-xl font-semibold text-slate-100 mb-6">Explore</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {sections.filter(s => s.count > 0).map(section => (
          <a href={section.href} class="group rounded-xl border border-slate-800 bg-slate-900/50 p-5 transition-all hover:border-green-600/30 hover:bg-slate-900">
            <div class="flex items-center justify-between">
              <h3 class="font-semibold text-slate-100 group-hover:text-green-400 transition-colors">{section.label}</h3>
              <span class="text-xs text-slate-600">{section.count}</span>
            </div>
            <p class="mt-1.5 text-sm text-slate-500">{section.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Featured -->
    {featured.length > 0 && (
      <section class="py-12 border-t border-slate-800">
        <h2 class="text-xl font-semibold text-slate-100 mb-6">Featured</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {featured.map(post => (
            <Card
              title={post.data.title}
              description={post.data.description}
              href={`/${categoryPath(post.data.category)}/${post.slug}`}
              tags={post.data.tags}
              date={post.data.date}
              category={post.data.category}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Recent -->
    {recentPosts.length > 0 && (
      <section class="py-12 border-t border-slate-800">
        <h2 class="text-xl font-semibold text-slate-100 mb-6">Recent</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {recentPosts.map(post => (
            <Card
              title={post.data.title}
              description={post.data.description}
              href={`/${categoryPath(post.data.category)}/${post.slug}`}
              tags={post.data.tags}
              date={post.data.date}
              category={post.data.category}
            />
          ))}
        </div>
      </section>
    )}
  </main>
  <Footer />
</BaseLayout>
