---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const featured = allPosts.filter(p => p.data.featured);
const recentPosts = allPosts
  .filter(p => p.data.date)
  .sort((a, b) => (b.data.date!.getTime() - a.data.date!.getTime()))
  .slice(0, 6);

function categoryPath(category: string) {
  if (category === 'study') return 'studies';
  if (category === 'project') return 'projects';
  if (category === 'tool') return 'tools';
  return category;
}

const studyCount = allPosts.filter(p => p.data.category === 'study').length;
const projectCount = allPosts.filter(p => p.data.category === 'project').length;
const researchCount = allPosts.filter(p => p.data.category === 'research').length;
const toolCount = allPosts.filter(p => p.data.category === 'tool').length;
const setupCount = allPosts.filter(p => p.data.category === 'setup').length;

const stats = [
  { label: 'Projects', value: projectCount },
  { label: 'Studies', value: studyCount },
  { label: 'Research', value: researchCount },
  { label: 'Total Posts', value: allPosts.length },
];

const sections = [
  { label: 'Studies', href: '/studies', description: 'Academic coursework and learning notes', count: studyCount },
  { label: 'Projects', href: '/projects', description: 'Software, hardware, and everything in between', count: projectCount },
  { label: 'Research', href: '/research', description: 'Deep dives and academic research', count: researchCount },
  { label: 'Tools', href: '/tools', description: 'Hardware, IoT, and dev tools', count: toolCount },
  { label: 'Setup', href: '/setup', description: 'Workspace and infrastructure', count: setupCount },
];
---

<BaseLayout title="Home" description="Aris Kurniawan — Software Engineer. Studies, projects, research, tools, and setup.">
  <Header />
  <main class="flex-1 w-full max-w-[1100px] mx-auto px-4 sm:px-8">
    <Hero stats={stats} />

    <!-- Sections Overview -->
    <section class="py-12 animate-fade-up-delay-2">
      <div class="flex items-center gap-3 mb-6">
        <span class="font-mono text-[10px] uppercase tracking-[3px] text-slate-600">Explore</span>
        <div class="flex-1 h-px bg-slate-800"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-slate-800">
        {sections.filter(s => s.count > 0).map(section => (
          <a href={section.href} class="group bg-[#111118] p-5 transition-all hover:bg-[#14141c]">
            <div class="flex items-center justify-between">
              <h3 class="font-semibold text-slate-100 group-hover:text-amber-400 transition-colors text-sm">{section.label}</h3>
              <span class="font-mono text-xs text-slate-700">{section.count}</span>
            </div>
            <p class="mt-1.5 text-xs text-slate-600 leading-relaxed">{section.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Featured -->
    {featured.length > 0 && (
      <section class="py-12 animate-fade-up-delay-3">
        <div class="flex items-center gap-3 mb-6">
          <span class="font-mono text-[10px] uppercase tracking-[3px] text-slate-600">Featured</span>
          <div class="flex-1 h-px bg-slate-800"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {featured.map(post => (
            <Card
              title={post.data.title}
              description={post.data.description}
              href={`/${categoryPath(post.data.category)}/${post.slug}`}
              tags={post.data.tags}
              date={post.data.date}
              category={post.data.category}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Recent -->
    {recentPosts.length > 0 && (
      <section class="py-12 animate-fade-up-delay-4">
        <div class="flex items-center gap-3 mb-6">
          <span class="font-mono text-[10px] uppercase tracking-[3px] text-slate-600">Recent</span>
          <div class="flex-1 h-px bg-slate-800"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {recentPosts.map(post => (
            <Card
              title={post.data.title}
              description={post.data.description}
              href={`/${categoryPath(post.data.category)}/${post.slug}`}
              tags={post.data.tags}
              date={post.data.date}
              category={post.data.category}
            />
          ))}
        </div>
      </section>
    )}
  </main>
  <Footer />
</BaseLayout>
