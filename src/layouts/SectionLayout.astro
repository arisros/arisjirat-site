---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="flex-1 w-full max-w-[1100px] mx-auto px-4 sm:px-8 py-10">
    <header class="mb-10 animate-fade-up">
      <div class="inline-block font-mono text-[10px] uppercase tracking-[2px] text-amber-500/60 border border-amber-500/20 px-3 py-1 mb-4">
        {title}
      </div>
      <h1 class="text-[clamp(1.75rem,4vw,2.5rem)] font-extrabold text-slate-100 tracking-tight">{title}</h1>
      {description && (
        <p class="mt-2 text-base text-slate-500">{description}</p>
      )}
    </header>
    <div class="animate-fade-up-delay-1">
      <slot />
    </div>
  </main>
  <Footer />
</BaseLayout>
