---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import type { Lang } from '@/lib/content';
import { DEFAULT_LANG, OTHER_LANG, langPrefix } from '@/lib/content';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const { title, description, lang = DEFAULT_LANG } = Astro.props;

const self = Astro.url.pathname;
const otherLangPath =
  lang === 'en'
    ? self.replace(/^\/en/, '') || '/'
    : self === '/'
      ? '/en'
      : `/en${self}`;
const alternates = { [lang]: self, [OTHER_LANG[lang]]: otherLangPath } as Record<Lang, string>;
---

<BaseLayout title={title} description={description} lang={lang} alternates={alternates}>
  <Header lang={lang} />
  <main class="flex-1 w-full max-w-[1100px] mx-auto px-4 sm:px-8 py-10">
    <header class="mb-10 animate-fade-up">
      <div class="inline-block font-mono text-[10px] uppercase tracking-[2px] text-accent border border-accent/30 rounded-pill px-3 py-1 mb-4">
        {title}
      </div>
      <h1 class="text-[clamp(1.75rem,4vw,2.5rem)] font-extrabold text-ink tracking-tight">{title}</h1>
      {description && (
        <p class="mt-2 text-base text-ink-muted">{description}</p>
      )}
    </header>
    <div class="animate-fade-up-delay-1">
      <slot />
    </div>
  </main>
  <Footer />
</BaseLayout>
