---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import TagList from '@components/TagList.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  category?: string;
  image?: string;
  repo?: string;
}

const { title, description, date, tags = [], category, image, repo } = Astro.props;

const categoryLabels: Record<string, string> = {
  study: 'Studies',
  project: 'Projects',
  research: 'Research',
  tool: 'Tools',
  setup: 'Setup',
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  ...(category
    ? [
        {
          label: categoryLabels[category] || category,
          href: `/${category === 'study' ? 'studies' : category === 'project' ? 'projects' : category === 'tool' ? 'tools' : category}`,
        },
      ]
    : []),
  { label: title },
];
---

<BaseLayout title={title} description={description} image={image}>
  <Header />
  <main class="flex-1 w-full max-w-[800px] mx-auto px-4 sm:px-6 py-8">
    <div class="animate-fade-up">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <article class="mt-6 animate-fade-up">
      {image && (
        <img
          src={image}
          alt={title}
          class="w-full rounded-xl border border-slate-800 mb-6"
          loading="eager"
        />
      )}
      <header class="mb-8">
        <h1 class="text-[clamp(1.5rem,4vw,2.25rem)] font-extrabold text-slate-100 leading-tight tracking-tight">
          {title}
        </h1>
        {description && (
          <p class="mt-3 text-lg text-slate-400">{description}</p>
        )}
        <div class="mt-4 flex flex-wrap items-center gap-4 font-mono text-[11px] text-slate-500">
          {date && (
            <time datetime={date.toISOString()}>
              {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          )}
          {tags.length > 0 && <TagList tags={tags} />}
        </div>
        {repo && (
          <a href={repo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 mt-3 text-sm text-amber-400 hover:text-amber-300 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            View Source
          </a>
        )}
      </header>

      <div class="prose prose-lg max-w-none">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
