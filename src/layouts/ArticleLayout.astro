---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import TagList from '@components/TagList.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  category?: string;
  image?: string;
}

const { title, description, date, tags = [], category, image } = Astro.props;

const categoryLabels: Record<string, string> = {
  study: 'Studies',
  project: 'Projects',
  research: 'Research',
  tool: 'Tools',
  setup: 'Setup',
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  ...(category
    ? [
        {
          label: categoryLabels[category] || category,
          href: `/${category === 'study' ? 'studies' : category === 'project' ? 'projects' : category === 'tool' ? 'tools' : category}`,
        },
      ]
    : []),
  { label: title },
];
---

<BaseLayout title={title} description={description} image={image}>
  <Header />
  <main class="flex-1 w-full max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={breadcrumbs} />

    <article class="mt-6">
      <header class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-100 leading-tight">
          {title}
        </h1>
        {description && (
          <p class="mt-3 text-lg text-slate-400">{description}</p>
        )}
        <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-slate-500">
          {date && (
            <time datetime={date.toISOString()}>
              {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          )}
          {tags.length > 0 && <TagList tags={tags} />}
        </div>
      </header>

      <div class="prose prose-lg max-w-none">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
